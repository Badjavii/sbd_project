<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SOJG_Reporte_Financiero_Avanzado" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f3d38510-1c1a-4713-98fe-08bb29094fe0">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Oracle_Docker_Lucia"/>
	<queryString>
		<![CDATA[WITH base_ingresos AS (
    SELECT 
        c.id_club,
        c.nombre AS nombre_club,
        ci.nombre AS ciudad,
        p.nombre AS pais,
        p.moneda AS moneda_local,
        EXTRACT(YEAR FROM pm.fecha) AS anno,
        SUM(pm.monto) AS ingresos_membresia_local
    FROM sojg_club c
    JOIN sojg_ciudad ci ON (c.id_ciudad = ci.id)
    JOIN sojg_pais p ON (ci.id_pais = p.id)
    LEFT JOIN sojg_pago_membresia pm ON (c.id_club = pm.id_club)
    WHERE pm.fecha IS NOT NULL
    GROUP BY c.id_club, c.nombre, ci.nombre, p.nombre, p.moneda, EXTRACT(YEAR FROM pm.fecha)
),
conversion_ingresos AS (
    SELECT 
        id_club,
        nombre_club,
        ciudad,
        pais,
        anno,
        -- Se aplica la función de conversión monetaria del esquema a USD (asumiendo tasa de cambio promedio de 1.00 si no aplica o la tasa real si viene de la tabla país)
        sojg_conversion_monetaria(ingresos_membresia_local, moneda_local, 1.00) AS ingresos_membresia_usd
    FROM base_ingresos
),
crecimiento_economico AS (
    SELECT 
        id_club,
        nombre_club,
        ciudad,
        pais,
        anno,
        ingresos_membresia_usd,
        LAG(ingresos_membresia_usd, 1) OVER (PARTITION BY id_club ORDER BY anno) AS ingresos_membresia_ant,
        ROUND(CASE 
            WHEN LAG(ingresos_membresia_usd, 1) OVER (PARTITION BY id_club ORDER BY anno) > 0 
            THEN ((ingresos_membresia_usd - LAG(ingresos_membresia_usd, 1) OVER (PARTITION BY id_club ORDER BY anno)) / LAG(ingresos_membresia_usd, 1) OVER (PARTITION BY id_club ORDER BY anno)) * 100
            ELSE 0 
        END, 2) AS pct_crec_economico
    FROM conversion_ingresos
),
miembros_por_anno AS (
    SELECT 
        id_club,
        EXTRACT(YEAR FROM fecha_inicio_membresia) AS m_anno,
        COUNT(DISTINCT id_miembro) AS miembros_fin
    FROM sojg_historico_membresia
    GROUP BY id_club, EXTRACT(YEAR FROM fecha_inicio_membresia)
),
crecimiento_miembros AS (
    SELECT 
        id_club,
        m_anno AS anno,
        miembros_fin,
        LAG(miembros_fin, 1) OVER (PARTITION BY id_club ORDER BY m_anno) AS miembros_inicio,
        ROUND(CASE 
            WHEN LAG(miembros_fin, 1) OVER (PARTITION BY id_club ORDER BY m_anno) > 0 
            THEN ((miembros_fin - LAG(miembros_fin, 1) OVER (PARTITION BY id_club ORDER BY m_anno)) / LAG(miembros_fin, 1) OVER (PARTITION BY id_club ORDER BY m_anno)) * 100
            ELSE 0 
        END, 2) AS pct_crec_miembros
    FROM miembros_por_anno
)
SELECT 
    ce.id_club,
    ce.nombre_club,
    ce.ciudad,
    ce.pais,
    ce.anno,
    ce.ingresos_membresia_usd,
    NVL(cm.pct_crec_miembros, 0) AS crecimiento_miembros_pct,
    NVL(ce.pct_crec_economico, 0) AS crecimiento_economico_pct
FROM crecimiento_economico ce
LEFT JOIN crecimiento_miembros cm ON (ce.id_club = cm.id_club AND ce.anno = cm.anno)
ORDER BY ce.pais DESC, ce.anno DESC, ce.nombre_club ASC]]>
	</queryString>
	<field name="ID_CLUB" class="java.math.BigDecimal"/>
	<field name="NOMBRE_CLUB" class="java.lang.String"/>
	<field name="CIUDAD" class="java.lang.String"/>
	<field name="PAIS" class="java.lang.String"/>
	<field name="ANNO" class="java.math.BigDecimal"/>
	<field name="INGRESOS_MEMBRESIA_USD" class="java.math.BigDecimal"/>
	<field name="CRECIMIENTO_MIEMBROS_PCT" class="java.math.BigDecimal"/>
	<field name="CRECIMIENTO_ECONOMICO_PCT" class="java.math.BigDecimal"/>
	<variable name="SUMA_GLOBAL_INGRESOS" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{INGRESOS_MEMBRESIA_USD}]]></variableExpression>
	</variable>
