<jasperReport name="SOJG_Reporte_Financiero_Avanzado" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f3d38510-1c1a-4713-98fe-08bb29094fe0">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Oracle_Docker_Lucia"/>
	<query language="sql"><![CDATA[SELECT 
            v.id_club,
            v.nombre_club,
            v.ciudad,
            CASE 
                WHEN LOWER(v.ciudad) LIKE '%caracas%' THEN 'Venezuela'
                WHEN LOWER(v.ciudad) LIKE '%roma%' OR LOWER(v.ciudad) LIKE '%milan%' THEN 'Italia'
                ELSE 'Argentina'
            END AS pais,
            v.anno,
            v.total_ingresos_membresia,
            v.total_recaudacion_obras,
            (v.total_ingresos_membresia + v.total_recaudacion_obras) AS ingresos_totales,
            (SELECT COUNT(DISTINCT h.numero_de_grupo) FROM SOJG_HISTORICO_GRUPO_LECTURA h WHERE h.id_club = v.id_club AND h.fecha_fin IS NULL) AS cantidad_grupos,
            CASE 
                WHEN (SELECT COUNT(*) FROM SOJG_HISTORICO_GRUPO_LECTURA h WHERE h.id_club = v.id_club AND h.fecha_fin IS NULL) > 0 
                THEN (v.total_ingresos_membresia + v.total_recaudacion_obras) / (SELECT COUNT(*) FROM SOJG_HISTORICO_GRUPO_LECTURA h WHERE h.id_club = v.id_club AND h.fecha_fin IS NULL)
                ELSE 0
            END AS ticket_promedio_usd
        FROM vw_reporte_financiero v
        WHERE v.anno IS NOT NULL
        ORDER BY pais ASC, v.anno DESC, v.nombre_club ASC]]></query>
	<field name="NOMBRE_CLUB" class="java.lang.String"/>
	<field name="CIUDAD" class="java.lang.String"/>
	<field name="PAIS" class="java.lang.String"/>
	<field name="ANNO" class="java.math.BigDecimal"/>
	<field name="TOTAL_INGRESOS_MEMBRESIA" class="java.math.BigDecimal"/>
	<field name="TOTAL_RECAUDACION_OBRAS" class="java.math.BigDecimal"/>
	<field name="INGRESOS_TOTALES" class="java.math.BigDecimal"/>
	<field name="CANTIDAD_GRUPOS" class="java.math.BigDecimal"/>
	<field name="TICKET_PROMEDIO_USD" class="java.math.BigDecimal"/>
	<variable name="SUMA_GLOBAL_INGRESOS" calculation="Sum" class="java.math.BigDecimal">
		<expression><![CDATA[$F{INGRESOS_TOTALES}]]></expression>
	</variable>
