				</graphicElement>
			</rectangle>
			<staticText>
				<reportElement x="15" y="16" width="230" height="15" forecolor="#2D3748" uuid="3d0e8841-a12b-42b7-a3a8-fa80cfbde32c"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="10" isBold="true"/>
				</textElement>
				<text><![CDATA[CRECIMIENTO ANUAL DE MIEMBROS:]]></text>
			</staticText>
			<textField pattern="#,##0.00 %">
				<reportElement x="250" y="16" width="85" height="15" forecolor="#2B6CB0" uuid="4fa217a4-31bf-4b95-a430-c081e748bde2"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="10" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{CREC_MIEMBROS_PCT}.doubleValue() / 100]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="15" y="38" width="230" height="15" forecolor="#2D3748" uuid="3d0e8841-a12b-42b7-a3a8-fa80cfbde32d"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="10" isBold="true"/>
				</textElement>
				<text><![CDATA[CRECIMIENTO ECONÓMICO ANUAL (USD):]]></text>
			</staticText>
			<textField pattern="#,##0.00 %">
				<reportElement x="250" y="38" width="85" height="15" forecolor="#2F855A" uuid="4fa217a4-31bf-4b95-a430-c081e748bde3"/>
				<textElement verticalAlignment="Middle">
					<font fontName="Arial" size="10" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{TIPO_CLUB}.equals("INDEPENDIENTE") ? ($F{CREC_ECONOMICO_PCT}.doubleValue() / 100) : 0.0]]></textFieldExpression>
			</textField>
			<textField>
