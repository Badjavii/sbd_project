<jasperReport name="SOJG_Ficha_Club_Personalizada" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="bc2da84a-71a2-4aef-bbdf-b749be9d4a41">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Oracle_Docker_Lucia"/>
	<parameter name="ID_CLUB_PARAM" class="java.math.BigDecimal">
		<description><![CDATA[Ingrese el ID del Club de Lectura que desea consultar]]></description>
	</parameter>
	<query language="sql"><![CDATA[SELECT 
            id_club,
            nombre_club,
            direccion,
            codigo_postal,
            idioma_del_club,
            ciudad,
            pais,
            tipo_club,
            NVL(institucion, 'Ninguna (Asociación Libre)') AS institucion,
            tipo_grupo,
            miembros_activos,
            NVL(libro_analizado, 'Sin registro de lectura') AS libro_analizado,
            NVL(TO_CHAR(valoracion), 'S/V') AS valoracion
        FROM sojg_v_reporte_ficha_club
        WHERE id_club = $P{ID_CLUB_PARAM}]]></query>
	<field name="ID_CLUB" class="java.math.BigDecimal"/>
	<field name="NOMBRE_CLUB" class="java.lang.String"/>
	<field name="DIRECCION" class="java.lang.String"/>
	<field name="CODIGO_POSTAL" class="java.lang.String"/>
	<field name="IDIOMA_DEL_CLUB" class="java.lang.String"/>
