<?xml version="1.0" encoding="UTF-8"?>
<!-- Created with Jaspersoft Studio version 9.0.3.final using JasperReports Library version 6.21.6-ef58807af469abb082e2f734b1e78a3c47daad18  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SOJG_Ficha_Club_Personalizada" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="bc2da84a-71a2-4aef-bbdf-b749be9d4a41">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Oracle_Docker_Lucia"/>
	<parameter name="ID_CLUB_PARAM" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Ingrese el ID del Club de Lectura que desea consultar]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[WITH 
historial_miembros AS (
    SELECT 
        id_club,
        EXTRACT(YEAR FROM fecha_inicio_membresia) AS list_anno,
        COUNT(DISTINCT id_miembro) AS total_m_anno
    FROM sojg_historico_membresia
    WHERE id_club = $P{ID_CLUB_PARAM}
    GROUP BY id_club, EXTRACT(YEAR FROM fecha_inicio_membresia)
),
crecimiento_m AS (
    SELECT 
        id_club,
        list_anno,
        total_m_anno,
        LAG(total_m_anno, 1) OVER (PARTITION BY id_club ORDER BY list_anno) AS total_m_ant,
        ROUND(CASE 
            WHEN LAG(total_m_anno, 1) OVER (PARTITION BY id_club ORDER BY list_anno) IS NOT NULL 
            THEN ((total_m_anno - LAG(total_m_anno, 1) OVER (PARTITION BY id_club ORDER BY list_anno)) / LAG(total_m_anno, 1) OVER (PARTITION BY id_club ORDER BY list_anno)) * 100
            ELSE 0 
        END, 2) AS pct_crec_miembros
    FROM historial_miembros
),
historial_financiero AS (
    SELECT 
        id_club,
        anno,
        (total_ingresos_membresia + total_recaudacion_obras) AS ingresos_totales
    FROM vw_reporte_financiero
    WHERE id_club = $P{ID_CLUB_PARAM}
),
crecimiento_f AS (
    SELECT 
        id_club,
        anno,
        ingresos_totales,
        LAG(ingresos_totales, 1) OVER (PARTITION BY id_club ORDER BY anno) AS ingresos_ant,
        ROUND(CASE 
            WHEN LAG(ingresos_totales, 1) OVER (PARTITION BY id_club ORDER BY anno) > 0 
            THEN ((ingresos_totales - LAG(ingresos_totales, 1) OVER (PARTITION BY id_club ORDER BY anno)) / LAG(ingresos_totales, 1) OVER (PARTITION BY id_club ORDER BY anno)) * 100
            ELSE 0 
        END, 2) AS pct_crec_economico
    FROM historial_financiero
)
SELECT
    c.id_club,
    c.nombre AS nombre_club,
    c.direccion,
    c.codigo_postal,
    c.idioma_del_club,
    ci.nombre AS ciudad,
    p.nombre AS pais,
    CASE WHEN c.cuota_membresia = 'SI' THEN 'INDEPENDIENTE' ELSE 'DEPENDIENTE' END AS tipo_club,
    NVL(i.nombre, 'Ninguna (Asociación Libre)') AS institucion,
    gl.categoria_edad AS tipo_grupo,
    gl.numero_de_grupo AS nro_grupo,
    
    -- Conteos blindados con UPPER y LIKE para evitar fallas de codificación/tildes en la letra 'Ñ'
    (SELECT COUNT(DISTINCT g1.numero_de_grupo) FROM sojg_grupo_de_lectura g1 WHERE g1.id_club = c.id_club AND UPPER(g1.categoria_edad) LIKE 'ADUL%') AS cant_grupos_adulto,
    (SELECT COUNT(DISTINCT g2.numero_de_grupo) FROM sojg_grupo_de_lectura g2 WHERE g2.id_club = c.id_club AND UPPER(g2.categoria_edad) LIKE 'JOVE%') AS cant_grupos_joven,
    (SELECT COUNT(DISTINCT g3.numero_de_grupo) FROM sojg_grupo_de_lectura g3 WHERE g3.id_club = c.id_club AND (UPPER(g3.categoria_edad) LIKE 'NI%' OR UPPER(g3.categoria_edad) LIKE 'NIN%')) AS cant_grupos_nino,
    
    l_member.nombre || ' ' || l_member.apellido AS miembro_nombre,
    NVL(li.titulo, 'Sin registro de lectura') AS libro_analizado,
    NVL(TO_CHAR(cm.valoracion_final), 'S/V') AS valoracion,
    
    NVL((SELECT MAX(pct_crec_miembros) FROM crecimiento_m WHERE id_club = c.id_club AND list_anno = (SELECT MAX(list_anno) FROM crecimiento_m WHERE id_club = c.id_club)), 0) AS crec_miembros_pct,
    NVL((SELECT MAX(pct_crec_economico) FROM crecimiento_f WHERE id_club = c.id_club AND anno = (SELECT MAX(anno) FROM crecimiento_f WHERE id_club = c.id_club)), 0) AS crec_economico_pct
FROM sojg_club c
JOIN sojg_ciudad ci ON (c.id_ciudad = ci.id)
JOIN sojg_pais p ON (ci.id_pais = p.id)
LEFT JOIN sojg_institucion i ON (c.id_institucion = i.id)
JOIN sojg_grupo_de_lectura gl ON (c.id_club = gl.id_club)
LEFT JOIN sojg_historico_grupo_lectura hg ON (gl.id_club = hg.id_club AND gl.numero_de_grupo = hg.numero_de_grupo AND hg.fecha_fin IS NULL)
LEFT JOIN sojg_lector l_member ON (hg.id_miembro = l_member.id_miembro)
LEFT JOIN sojg_calendario_mes cm ON (gl.id_club = cm.id_club AND gl.numero_de_grupo = cm.numero_de_grupo AND cm.realizada = 'SI')
LEFT JOIN sojg_libro li ON (cm.isbn_libro = li.isbn)
WHERE c.id_club = $P{ID_CLUB_PARAM}
ORDER BY gl.categoria_edad ASC, gl.numero_de_grupo ASC, l_member.apellido ASC, cm.valoracion_final DESC NULLS LAST]]>
	</queryString>
