		<parameter name="P_ID_MIEMBRO" class="java.lang.Integer"/>
		<queryString language="SQL">
			<![CDATA[SELECT ID_CLUB, FECHA_INICIO_MEMBRESIA, FECHA_FIN, ESTATUS, MOTIVO_RETIRO
FROM SOJG_HISTORICO_MEMBRESIA
WHERE ID_MIEMBRO = $P{P_ID_MIEMBRO}]]>
		</queryString>
		<field name="ID_CLUB" class="java.math.BigDecimal"/>
		<field name="FECHA_INICIO_MEMBRESIA" class="java.sql.Timestamp"/>
		<field name="FECHA_FIN" class="java.sql.Timestamp"/>
		<field name="ESTATUS" class="java.lang.String"/>
		<field name="MOTIVO_RETIRO" class="java.lang.String"/>
	</subDataset>
