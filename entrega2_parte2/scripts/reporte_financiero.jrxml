<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="SOJG_Reporte_Financiero_Avanzado" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f3d38510-1c1a-4713-98fe-08bb29094fe0">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Oracle Adapter"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<queryString>
		<![CDATA[WITH ConteoGrupos AS (
    SELECT 
        h.id_club,
        COUNT(DISTINCT h.numero_de_grupo) AS cant_grupos_distinct,
        COUNT(*) AS cant_grupos_total
    FROM SOJG_HISTORICO_GRUPO_LECTURA h
    WHERE h.fecha_fin IS NULL
    GROUP BY h.id_club
)
SELECT 
    v.id_club,
    v.nombre_club,
    v.ciudad,
    p.nombre AS pais,
    v.anno,
    NVL(v.total_ingresos_membresia, 0) AS total_ingresos_membresia,
    NVL(v.total_recaudacion_obras, 0) AS total_recaudacion_obras,
    NVL(v.total_ingresos_membresia, 0) + NVL(v.total_recaudacion_obras, 0) AS ingresos_totales,
    NVL(cg.cant_grupos_distinct, 0) AS cantidad_grupos,
    CASE 
        WHEN (NVL(cg.cant_grupos_total, 0) > 0)
        THEN NVL(v.total_ingresos_membresia, 0) + NVL(v.total_recaudacion_obras, 0) / cg.cant_grupos_total
        ELSE 0
    END AS ticket_promedio_usd
FROM vw_reporte_financiero v
LEFT JOIN SOJG_CLUB c ON (v.id_club = c.id_club)
LEFT JOIN SOJG_CIUDAD ci ON (c.id_ciudad = ci.id)
LEFT JOIN SOJG_PAIS p ON (ci.id_pais = p.id)
LEFT JOIN ConteoGrupos cg ON (v.id_club = cg.id_club)
WHERE v.anno IS NOT NULL
ORDER BY p.nombre ASC, v.anno DESC, v.nombre_club ASC]]>
	</queryString>
