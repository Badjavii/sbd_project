	<parameter name="ID_CLUB_PARAM" class="java.math.BigDecimal">
		<parameterDescription><![CDATA[Ingrese el ID del Club de Lectura que desea consultar]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    id_club,
    nombre_club,
    direccion,
    codigo_postal,
    idioma_del_club,
    ciudad,
    pais,
    tipo_club,
    NVL(institucion, 'Ninguna (Asociación Libre)') AS institucion,
    tipo_grupo,
    miembros_activos,
    NVL(libro_analizado, 'Sin registro de lectura') AS libro_analizado,
    NVL(TO_CHAR(valoracion), 'S/V') AS valoracion
FROM sojg_v_reporte_ficha_club
WHERE id_club = $P{ID_CLUB_PARAM}]]>
	</queryString>
