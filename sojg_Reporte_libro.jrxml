<jasperReport name="SOJG_Ficha_Libro_Estricta" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="bc2da84a-71a2-4aef-bbdf-b749be9d4a41">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Oracle_Docker"/>
	<parameter name="ISBN_PARAM" class="java.lang.String">
		<description><![CDATA[Ingrese el código ISBN del libro a consultar]]></description>
	</parameter>
	<query language="sql"><![CDATA[SELECT 
            ISBN,
            TITULO_LIBRO,
            AUTORES,
            ANNO_PUBLICACION,
            PAIS_PUBLICACION,
            DECODE(ES_PRIMERA_EDICION, 'SI', 'Primera Edición', 'Reedición') AS TEXTO_EDICION,
            TIPO_NARRATIVA,
            IDIOMA,
            TEMA_RESUMEN,
            SINOPSIS,
            NVL(CONTINUA_EN_SERIE, 'Obra Autónoma (No pertenece a una saga)') AS CONTINUA_EN_SERIE,
            NVL(TO_CHAR(VALORACION_PROMEDIO_GLOBAL), 'S/V') AS VALORACION_PROMEDIO_GLOBAL,
            NVL(CLUB_QUE_ANALIZO, 'Sin análisis registrado aún') AS CLUB_QUE_ANALIZO,
            NVL(TO_CHAR(GRUPO_LECTOR), '-') AS GRUPO_LECTOR,
            NVL(CONCLUSIONES_DEL_GRUPO, 'El grupo no registró conclusiones escritas en este periodo.') AS CONCLUSIONES_DEL_GRUPO
        FROM sojg_v_ficha_libro
        WHERE ISBN = $P{ISBN_PARAM}]]></query>
	<field name="ISBN" class="java.lang.String"/>
	<field name="TITULO_LIBRO" class="java.lang.String"/>
	<field name="AUTORES" class="java.lang.String"/>
	<field name="ANNO_PUBLICACION" class="java.math.BigDecimal"/>
	<field name="PAIS_PUBLICACION" class="java.lang.String"/>
